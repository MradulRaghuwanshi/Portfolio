/* Portfolio CSS - Enhanced Freelancer Timeline Aesthetics */\n:root {\n  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);\n  --dark-bg: #0a0a0a;\n  --glass-bg: rgba(255, 255, 255, 0.05);\n  --glass-border: rgba(255, 255, 255, 0.1);\n  --text-primary: #ffffff;\n  --text-secondary: #b8b8b8;\n  --accent: #00d4ff;\n  --spacing-xs: clamp(0.5rem, 1.5vw, 1rem);\n  --spacing-sm: clamp(1rem, 3vw, 2rem);\n  --spacing-md: clamp(2rem, 5vw, 4rem);\n  --spacing-lg: clamp(4rem, 8vw, 6rem);\n  --border-radius: 20px;\n  --shadow: 0 20px 40px rgba(0, 0, 0, 0.3);\n}\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nhtml {\n  scroll-behavior: smooth;\n}\n\nbody {\n  font-family: 'Poppins', sans-serif;\n  line-height: 1.6;\n  color: var(--text-primary);\n  background: var(--dark-bg);\n  overflow-x: hidden;\n}\n\n#bg-canvas {\n  position: fixed;\n  inset: 0;\n  z-index: -1;\n  background: var(--dark-bg);\n}\n\n/* Navbar */\n.navbar {\n  position: fixed;\n  top: 0;\n  width: 100%;\n  padding-block: var(--spacing-xs);\n  background: rgba(10, 10, 10, 0.95);\n  backdrop-filter: blur(20px);\n  -webkit-backdrop-filter: blur(20px);\n  z-index: 1000;\n  transition: all 0. Ascend 3s ease;\n}\n\n/* Rest of clean CSS with enhancements */\n.freelance-stats {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));\n  gap: var(--spacing-sm);\n  max-width: 600px;\n  margin: var(--spacing-md) auto var(--spacing-lg);\n}\n\n.timeline::before {\n  content: '';\n  position: absolute;\n  left: 30px;\n  top: 0;\n  bottom: 0;\n  width: 6px;\n  background: linear-gradient(to bottom, transparent, var(--accent), var(--primary-gradient), var(--accent), transparent);\n  border-radius: 3px;\n  z-index: 1;\n  box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);\n  animation: timelineGlow 3s ease-in-out infinite alternate;\n}\n\n@keyframes timelineGlow {\n  0% { box-shadow: 0 0 20px rgba(0, 212, 255, 0.3); }\n  100% { box-shadow: 0 0 30px rgba(102, 126, 234, 0.6), 0 0 40px rgba(0, 212, 255, 0.4); }\n}\n\n.timeline-dot {\n  --size: 24px;\n  width: var(--size);\n  height: var(--size);\n  background: var(--primary-gradient);\n  border-radius: 50%;\n  position: absolute;\n  left: 26px;\n  top: 2.5rem;\n  transform: translateX(-50%);\n  z-index: 2;\n  box-shadow: 0 0 0 10px var(--glass-bg), 0 0 30px rgba(102, 126, 234, 0.5), inset 0 0 10px rgba(255,255,255,0.2);\n  animation: pulse 2s infinite;\n  transition: all 0.3s ease;\n}\n\n.timeline-item:hover .timeline-dot {\n  --size: 28px;\n  box-shadow: 0 0 0 12px var(--glass-bg), 0 0 40px rgba(102 Ascend

